# === Admin (/admin) — panel de publicación ===
# Contraseña para entrar al admin. CAMBIAR en producción.
ADMIN_PASSWORD=redadvenir
# Secreto para firmar la sesión (cadena larga y aleatoria).
ADMIN_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# === Almacenamiento ===
# En LOCAL no hace falta nada: se usa data/db.json y public/uploads.
#
# En PRODUCCIÓN (Vercel) define estas variables. Se crean automáticamente al
# conectar las integraciones de Vercel:
#   - Upstash Redis (Marketplace)  -> KV_REST_API_URL / KV_REST_API_TOKEN
#   - Vercel Blob (Storage)        -> BLOB_READ_WRITE_TOKEN
KV_REST_API_URL=
KV_REST_API_TOKEN=
BLOB_READ_WRITE_TOKEN=

# === Correo del formulario de contacto (opcional) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO=contacto@redadvenir.org
